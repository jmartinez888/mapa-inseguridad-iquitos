generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model IncidentReport {
  id              String   @id @default(uuid())
  district        String
  incidentType    String
  stolenObject    String
  victimGender    String

  latitude        Float
  longitude       Float

  exactDate       DateTime?
  approximateDate String?

  timeOfDay       String
  description     String?
  contactInfo     String?

  createdAt       DateTime @default(now())
}