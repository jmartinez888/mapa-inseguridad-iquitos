generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model IncidentReport {
  id             String   @id @default(uuid())
  lat            Float
  lng            Float
  district       String   // Guardará el Distrito
  province       String?  // <-- AGREGAR (Opcional por si acaso)
  state          String?  // <-- AGREGAR (Guardará el Departamento)
  incidentType   String   // Tipo de incidente
  stolenObject   String?  // <-- CAMBIAR A OPCIONAL con el '?' (Aquí va el detalle dinámico)
  victimGender   String
  incidentYear   Int
  incidentMonth  Int?
  incidentDay    Int?
  timeOfDay      String
  mobility       String
  economicImpact String
  description    String?  // Opcional si lo tenías así
  contactInfo    String?  // Opcional
  createdAt      DateTime @default(now())
}